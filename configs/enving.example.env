# RTX 4060 Laptop GPU 本机 smoke 运行参数。
# 复制为 configs/enving.env 后，把三个镜像改成 Kubernetes 集群可拉取的地址。
NAMESPACE=bench
MASTER_IMAGE=vllm-bench-platform/master:local
BENCH_RUNNER_IMAGE=vllm-bench-platform/bench-runner:local
TARGET_VLLM_IMAGE=vllm/vllm-openai:v0.8.5
TARGET_RESOURCE_NAME=nvidia.com/gpu
TARGET_RESOURCE_COUNT=1
MODEL_PATH=Qwen/Qwen2.5-0.5B-Instruct
MODEL_NAME=Qwen2.5-0.5B-Instruct
SERVED_MODEL_NAME=Qwen2.5-0.5B-Instruct
DTYPE=float16
RESULTS_HOST_PATH=/tmp/vllm-bench-results
BENCH_COMMAND=vllm bench serve
BENCH_TIMEOUT_SECONDS=600
BENCH_NUM_PROMPTS=2
BENCH_RUNNER_HEALTH_TIMEOUT_SECONDS=600
BENCH_RUNNER_REQUEST_TIMEOUT_SECONDS=660
MASTER_MEMORY_REQUEST=256Mi
MASTER_MEMORY_LIMIT=512Mi
BENCH_RUNNER_MEMORY_REQUEST=1Gi
BENCH_RUNNER_MEMORY_LIMIT=2Gi
TARGET_ENV_JSON={"HF_HUB_DISABLE_XET":"1"}
HEALTH_PATH=/health
TARGET_PORT=8000
POD_TOLERATIONS_JSON=[{"key":"node-role.kubernetes.io/control-plane","operator":"Exists","effect":"NoSchedule"}]
