# Kubernetes namespace，所有本次 run 的资源都会创建在这里。
NAMESPACE=bench

# Master Job 镜像，里面包含平台代码、kubectl 和 vllm-bench。
MASTER_IMAGE=vllm-bench-platform/master:local

# target vLLM Pod 镜像，真正加载模型并提供 OpenAI-compatible API。
TARGET_VLLM_IMAGE=vllm/vllm-openai:v0.8.5

# target Pod 申请的加速卡资源名，NVIDIA GPU 通常是 nvidia.com/gpu。
TARGET_RESOURCE_NAME=nvidia.com/gpu

# target Pod 申请的加速卡数量。
TARGET_RESOURCE_COUNT=1

# vLLM tensor parallel size，需与 PIPELINE_PARALLEL_SIZE 相乘等于 TARGET_RESOURCE_COUNT。
TENSOR_PARALLEL_SIZE=1

# vLLM pipeline parallel size，需与 TENSOR_PARALLEL_SIZE 相乘等于 TARGET_RESOURCE_COUNT。
PIPELINE_PARALLEL_SIZE=1

# 传给 vLLM 的 --model；默认使用 Hugging Face repo id，让 target Pod 按需下载或复用 cache。
MODEL_PATH=Qwen/Qwen2.5-0.5B-Instruct

# 模型名称记录字段；不参与 GPU/TP/PP 配置。
MODEL_NAME=Qwen2.5-0.5B-Instruct

# vLLM 对外暴露的模型名，vllm-bench 请求里的 model 字段会使用它。
SERVED_MODEL_NAME=Qwen2.5-0.5B-Instruct

# vLLM 加载模型时使用的数据类型。
DTYPE=float16

# 可选：宿主机上的完整模型目录；默认 Hugging Face cache 模式下留空。
MODEL_HOST_PATH=

# 可选：模型目录挂到 target 容器内的位置；MODEL_HOST_PATH 留空时这里也留空。
MODEL_MOUNT_PATH=

# Hugging Face cache 在宿主机上的持久化目录，用于避免 target Pod 反复下载模型。
MODEL_CACHE_HOST_PATH=/tmp/vllm-bench/model-cache

# Hugging Face cache 挂到 target 容器内的位置。
MODEL_CACHE_MOUNT_PATH=/root/.cache/huggingface

# 结果持久化根目录，实际 run 目录为 {PERSIST_ROOT}/{NAMESPACE}/{run_id}。
PERSIST_ROOT=/tmp/vllm-bench

# Master 容器内的 vllm-bench 可执行文件名或路径。
BENCH_BINARY=vllm-bench

# 单个 benchmark case 的超时时间，单位秒。
BENCH_TIMEOUT_SECONDS=600

# 测试请求数量，会传给 vllm-bench。
BENCH_NUM_PROMPTS=2

# Master 容器内存 request。
MASTER_MEMORY_REQUEST=256Mi

# Master 容器内存 limit。
MASTER_MEMORY_LIMIT=512Mi

# 注入 target vLLM 容器的额外环境变量，JSON object 格式。
TARGET_ENV_JSON={"HF_HUB_DISABLE_XET":"1"}

# target vLLM server 的健康检查路径。
HEALTH_PATH=/health

# target vLLM server 的 HTTP 端口。
TARGET_PORT=8000

# Master 和 target Pod 的 tolerations，JSON array 格式；本地单节点 control-plane 常需要这个。
POD_TOLERATIONS_JSON=[{"key":"node-role.kubernetes.io/control-plane","operator":"Exists","effect":"NoSchedule"}]
